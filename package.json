{
  "name": "virtual-art-prod",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-scripts": "5.0.1",
    "lucide-react": "^0.383.0",
    "framer-motion": "^11.0.0",
    "react-intersection-observer": "^9.8.1",
    "react-helmet-async": "^2.0.4",
    "@emailjs/browser": "^4.3.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "postbuild": "react-snap"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
  "homepage": "/",
  "devDependencies": {
    "react-snap": "^1.23.0"
  },
  "reactSnap": {
    "source": "build",
    "inlineCss": false,
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    },
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "include": [
      "/",
      "/a-propos",
      "/services",
      "/portfolio",
      "/devis",
      "/blog",
      "/contact",
      "/privacy",
      "/conditions-utilisation",
      "/blog/tendances-video-communication-entreprise",
      "/blog/presence-linkedin-nouveaux-clients",
      "/blog/visite-virtuelle-360-hotellerie",
      "/blog/roi-publicite-video-vs-display",
      "/blog/drone-reglementation-algerie",
      "/blog/storytelling-entreprise"
    ]
  }
}
